@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Setup 2FA</title>

    <style>

        body {
            font-family: Arial;
            text-align: center;
            margin-top: 100px;
        }

        img {
            margin-top: 20px;
        }

    </style>

</head>

<body>

    
    <h2>Setup Two Factor Authentication</h2>

    <p>Scan this QR code using Authenticator App</p>

    <img src="data:image/png;base64,@ViewBag.QRCode" width="200" />

    <form method="post" action="/Account/VerifySetupOTP">

        <label>Enter OTP</label>
        <input type="text" name="otp" />

        <button type="submit">Verify</button>

    </form>

</body>
</html>