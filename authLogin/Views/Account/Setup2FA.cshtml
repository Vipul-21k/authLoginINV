@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Setup 2FA</title>

    <style>

        body {
            font-family: Arial;
            text-align: center;
            margin-top: 100px;
        }

        img {
            margin-top: 20px;
        }

    </style>

</head>

<body>

    <h2>Two Factor Authentication Setup</h2>

    <p>Scan this QR Code with Microsoft Authenticator</p>

    <img src="data:image/png;base64,@ViewBag.QRCode" />

    <br>
    <br>

    <p>Secret Key</p>

    <b>@ViewBag.SecretKey</b>

    <br>
    <br>

    <a href="/Account/Login">Go to Login</a>

</body>
</html>