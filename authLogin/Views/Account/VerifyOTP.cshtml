@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>OTP Verification</title>

    <style>

        body {
            font-family: Arial;
            background: #f3f3f3;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .card {
            background: white;
            padding: 40px;
            width: 320px;
            box-shadow: 0 0 10px rgba(0,0,0,0.2);
            text-align: center;
        }

        input {
            width: 100%;
            padding: 10px;
            margin-top: 10px;
            margin-bottom: 20px;
        }

        button {
            width: 100%;
            padding: 10px;
            background: #0078D4;
            color: white;
            border: none;
        }

    </style>

</head>

<body>

    <div class="card">

        <h2>Enter Authentication Code</h2>

        <p>Open Microsoft Authenticator and enter the code</p>

        <form method="post">

            <input type="text" name="otp" placeholder="6 digit code" required />

            <button type="submit">Verify</button>

        </form>

    </div>

</body>
</html>